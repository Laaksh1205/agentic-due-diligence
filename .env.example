# ============================================================
# Due Diligence Platform — Environment Variables
# Copy this file to .env and fill in your real API keys.
# NEVER commit .env to git.
# ============================================================

# --- LLM Provider (choose one) ---
# Gemini (recommended — generous free tier)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_FAST_MODEL=gemini-2.5-flash
GEMINI_SMART_MODEL=gemini-2.5-pro

# OpenAI (alternative)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_FAST_MODEL=gpt-4.1-mini
# OPENAI_SMART_MODEL=gpt-4.1

# --- Web Search ---
# Tavily: https://tavily.com — free tier: 1,000 searches/month
TAVILY_API_KEY=your_tavily_api_key_here

# --- Company Registry MCP Servers ---
# Registry Lookup: https://registry-lookup.com/dashboard
# Free tier: 5,000 calls/month, 1,000/day, 10 req/sec
REGISTRY_LOOKUP_API_KEY=your_registry_lookup_api_key_here

# Companies House: https://developer.company-information.service.gov.uk
# Free, unlimited
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key_here

# --- News API (Phase 5.6) ---
# NewsAPI.org: https://newsapi.org — free tier: 100 req/day
# Optional: if unset, the News source is skipped and other sources still run.
NEWS_API_KEY=your_news_api_key_here

# --- Monitoring (Phase 3 only) ---
# Langfuse: https://langfuse.com — free cloud tier or self-hosted
# LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
# LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Database ---
DATABASE_PATH=data/due_diligence.db

# --- Guardrails (override defaults in config.py if needed) ---
# MAX_LLM_CALLS=50
# MAX_COST_USD=1.00
# MAX_WALL_CLOCK_SECONDS=600
