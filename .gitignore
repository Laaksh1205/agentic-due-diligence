# =============================================================
# Due Diligence Intelligence Platform — .gitignore
# =============================================================

# ── Secrets & environment ──────────────────────────────────
# Ignore ALL .env variants EXCEPT the committed example files
.env
.env.*
!.env.example
!.env.*.example
# frontend-specific env overrides
frontend/.env.local
frontend/.env.*.local
# Any stray credential or certificate files
*.pem
*.key
*.crt
*.p12
secrets/

# ── Python ────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
*.eggs/
dist/
build/
wheels/
pip-log.txt
pip-delete-this-directory.txt
.python-version
# Test & coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
coverage.json
htmlcov/
# Type checkers / linters
.mypy_cache/
.ruff_cache/
.pyright/
# MkDocs
site/

# ── Data, outputs & generated files ───────────────────────
# Runtime database (rebuilt automatically on first run)
data/
*.db
*.sqlite
*.sqlite3
# Generated report exports (PDF / JSON dumps from the pipeline)
output/
# Temporary / scratch
tmp/
temp/
logs/
*.log

# ── FAISS knowledge-base index ─────────────────────────────
# Rebuild via: python -m src.analysis.knowledge_base
knowledge_base/*.faiss
knowledge_base/*.pkl
knowledge_base/*.index
knowledge_base/severity_chunks.json

# ── Evaluation run results ─────────────────────────────────
# Time-stamped result snapshots generated by the eval harness.
# Ground-truth files (evaluation/ground_truth/) ARE committed.
evaluation/results_*.json
evaluation/extraction_eval_results.json
evaluation/__pycache__/

# ── Frontend (Next.js / Node) ──────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/*.tsbuildinfo
# Playwright test artefacts
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/
frontend/.last-run.json

# ── Docker ────────────────────────────────────────────────
# Don't ignore docker-compose.yml or Dockerfile — those are source.
# Ignore any local override files.
docker-compose.override.yml
docker-compose.local.yml

# ── IDE & editor ──────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Observability / third-party local stacks ──────────────
langfuse/
graphify-out/
